  </div>
</div>

<!-- ALL PHOTOS SECTION -->
<div id="all-photos">
  <div class="section">
    <div class="section-header">
      <h2 class="section-title">All <em>Photos</em></h2>
      <div class="section-line"></div>
      <span class="section-count" id="photo-count"></span>
    </div>
    <div class="filter-bar">
      <div class="search-wrap">
        <span class="search-icon">⌕</span>
        <input type="text" id="search-input" placeholder="Search photos…" oninput="filterPhotos()">
      </div>
      <div class="filter-tags" id="filter-tags"></div>
    </div>
    <div class="masonry" id="masonry-grid"></div>
  </div>
</div>

<!-- ALBUM VIEWER OVERLAY -->
<div id="album-viewer">
  <div class="av-header">
    <button class="av-back" onclick="closeAlbumViewer()">← Back</button>
    <h2 class="av-title" id="av-title"></h2>
    <span class="av-count" id="av-count"></span>
  </div>
  <div class="av-grid" id="av-grid"></div>
</div>

<!-- LIGHTBOX -->
<div id="lightbox" onclick="lbClickOverlay(event)">
  <div class="lb-content">
    <button class="lb-close" onclick="closeLightbox()">✕</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-progress" id="lb-progress"></div>
    <div class="lb-caption">
      <div class="caption-title" id="lb-title"></div>
      <div class="caption-date" id="lb-date"></div>
    </div>
    <div class="lb-counter" id="lb-counter"></div>
    <button class="lb-slideshow-btn" id="lb-ss-btn" onclick="toggleSlideshow()">▶ Slideshow</button>
  </div>
  <button class="lb-nav" id="lb-prev" onclick="lbNav(-1)">‹</button>
  <button class="lb-nav" id="lb-next" onclick="lbNav(1)">›</button>
</div>

<footer>
  <span>Sommer Ray</span> — Personal Photo Library &nbsp;·&nbsp; All rights reserved
</footer>

<!-- =====================================================
     JAVASCRIPT
===================================================== -->
<script>
// ---- STATE ----
let currentPhotos   = [];  // flat array for lightbox
let lbIndex         = 0;
let slideshowTimer  = null;
let slideshowActive = false;
const SLIDESHOW_DELAY = 3500;

// ---- INIT ----
document.addEventListener('DOMContentLoaded', () => {
  // Video background
  const vid = document.getElementById('bg-video');
  if (CONFIG.videoBg) {
    vid.src = CONFIG.videoBg;
    document.getElementById('hero-fallback').style.display = 'none';
  } else {
    vid.style.display = 'none';
  }

  buildAlbums();
  buildMasonry(getAllPhotos());
  buildFilterTags();
  setupNavScroll();
  setupIntersectionObserver();
  setupKeyboard();
});

function getAllPhotos() {
  return CONFIG.albums.flatMap(a => a.photos);
}

// ---- ALBUMS ----
function buildAlbums() {
  const grid = document.getElementById('albums-grid');
  document.getElementById('album-count').textContent = CONFIG.albums.length + ' albums';
  CONFIG.albums.forEach((album, i) => {
    const card = document.createElement('div');
    card.className = 'album-card';
    card.innerHTML = `
      <img class="album-thumb" src="${album.cover}" alt="${album.name}" loading="lazy">
      <div class="album-info">
        <div class="album-name">${album.name}</div>
        <div class="album-meta">${album.photos.length} photos</div>
      </div>
      <div class="album-hover-cta">
        <button class="album-cta-btn">Open Album</button>
      </div>`;
    card.addEventListener('click', () => openAlbumViewer(i));
    grid.appendChild(card);
  });
}

// ---- ALBUM VIEWER ----
function openAlbumViewer(albumIndex) {
  const album = CONFIG.albums[albumIndex];
  document.getElementById('av-title').textContent = album.name;
  document.getElementById('av-count').textContent = album.photos.length + ' photos';
  const grid = document.getElementById('av-grid');
  grid.innerHTML = '';
  album.photos.forEach((photo, i) => {
    const item = document.createElement('div');
    item.className = 'masonry-item visible';
    item.innerHTML = `
      <img src="${photo.src}" alt="${photo.title}" loading="lazy">
      <div class="photo-caption">
        <div class="caption-title">${photo.title}</div>
        <div class="caption-date">${photo.date}</div>
      </div>`;
    item.addEventListener('click', () => {
      currentPhotos = album.photos;
      openLightbox(i);
    });
    grid.appendChild(item);
  });
  document.getElementById('album-viewer').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeAlbumViewer() {
  document.getElementById('album-viewer').classList.remove('open');
  document.body.style.overflow = '';
}

// ---- MASONRY GRID ----
function buildMasonry(photos) {
  const grid = document.getElementById('masonry-grid');
  grid.innerHTML = '';
  document.getElementById('photo-count').textContent = photos.length + ' photos';
  photos.forEach((photo, i) => {
    const item = document.createElement('div');
    item.className = 'masonry-item';
    item.dataset.title = (photo.title || '').toLowerCase();
    item.dataset.tags  = (photo.tags || []).join(' ').toLowerCase();
    item.innerHTML = `
      <img src="${photo.src}" alt="${photo.title}" loading="lazy">
      <div class="photo-caption">
        <div class="caption-title">${photo.title}</div>
        <div class="caption-date">${photo.date}</div>
      </div>`;
    item.addEventListener('click', () => {
      currentPhotos = getAllPhotos();
      openLightbox(currentPhotos.indexOf(photo));
    });
    grid.appendChild(item);
  });
  setupIntersectionObserver();
}

// ---- FILTER ----
function buildFilterTags() {
  const all = getAllPhotos();
  const tagSet = new Set(all.flatMap(p => p.tags || []));
  const container = document.getElementById('filter-tags');
  const allBtn = document.createElement('button');
  allBtn.className = 'filter-tag active';
  allBtn.textContent = 'All';
  allBtn.dataset.tag = '';
  allBtn.addEventListener('click', () => setActiveTag(allBtn, ''));
  container.appendChild(allBtn);
  tagSet.forEach(tag => {
    const btn = document.createElement('button');
    btn.className = 'filter-tag';
    btn.textContent = tag;
    btn.dataset.tag = tag;
    btn.addEventListener('click', () => setActiveTag(btn, tag));
    container.appendChild(btn);
  });
}

function setActiveTag(btn, tag) {
  document.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterPhotos(tag);
}

function filterPhotos(forcedTag) {
  const query = document.getElementById('search-input').value.toLowerCase();
  const tag   = forcedTag !== undefined ? forcedTag :
                (document.querySelector('.filter-tag.active')?.dataset.tag || '');
  document.querySelectorAll('.masonry-item').forEach(item => {
    const titleMatch = !query || item.dataset.title.includes(query);
    const tagMatch   = !tag   || item.dataset.tags.includes(tag);
    item.style.display = (titleMatch && tagMatch) ? '' : 'none';
  });
}

// ---- LIGHTBOX ----
function openLightbox(index) {
  lbIndex = index;
  renderLightbox();
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  stopSlideshow();
  if (!document.getElementById('album-viewer').classList.contains('open')) {
    document.body.style.overflow = '';
  }
}

function renderLightbox() {
  const photo = currentPhotos[lbIndex];
  const img   = document.getElementById('lb-img');
  img.style.opacity = '0';
  img.src = photo.src;
  img.onload = () => { img.style.opacity = '1'; img.style.transition = 'opacity 0.3s'; };
  document.getElementById('lb-title').textContent   = photo.title || '';
  document.getElementById('lb-date').textContent    = photo.date  || '';
  document.getElementById('lb-counter').textContent =
    (lbIndex + 1) + ' / ' + currentPhotos.length;
}

function lbNav(dir) {
  lbIndex = (lbIndex + dir + currentPhotos.length) % currentPhotos.length;
  renderLightbox();
  if (slideshowActive) resetSlideshowTimer();
}

function lbClickOverlay(e) {
  if (e.target === document.getElementById('lightbox')) closeLightbox();
}

// ---- SLIDESHOW ----
function toggleSlideshow() {
  slideshowActive ? stopSlideshow() : startSlideshow();
}

function startSlideshow() {
  slideshowActive = true;
  document.getElementById('lb-ss-btn').textContent = '⏸ Pause';
  document.getElementById('lb-ss-btn').classList.add('playing');
  resetSlideshowTimer();
}

function stopSlideshow() {
  slideshowActive = false;
  clearInterval(slideshowTimer);
  document.getElementById('lb-ss-btn').textContent = '▶ Slideshow';
  document.getElementById('lb-ss-btn').classList.remove('playing');
  const prog = document.getElementById('lb-progress');
  prog.style.transition = 'none';
  prog.style.width = '0%';
}

function resetSlideshowTimer() {
  clearInterval(slideshowTimer);
  const prog = document.getElementById('lb-progress');
  prog.style.transition = 'none';
  prog.style.width = '0%';
  requestAnimationFrame(() => {
    prog.style.transition = `width ${SLIDESHOW_DELAY}ms linear`;
    prog.style.width = '100%';
  });
  slideshowTimer = setInterval(() => {
    lbIndex = (lbIndex + 1) % currentPhotos.length;
    renderLightbox();
    const p = document.getElementById('lb-progress');
    p.style.transition = 'none'; p.style.width = '0%';
    requestAnimationFrame(() => {
      p.style.transition = `width ${SLIDESHOW_DELAY}ms linear`;
      p.style.width = '100%';
    });
  }, SLIDESHOW_DELAY);
}

// ---- KEYBOARD ----
function setupKeyboard() {
  document.addEventListener('keydown', e => {
    const lb = document.getElementById('lightbox').classList.contains('open');
    if (!lb) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') lbNav(1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   lbNav(-1);
    if (e.key === 'Escape') closeLightbox();
    if (e.key === ' ') { e.preventDefault(); toggleSlideshow(); }
  });
}

// ---- NAVBAR SCROLL ----
function setupNavScroll() {
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
  });
}

// ---- INTERSECTION OBSERVER (fade-in masonry items) ----
function setupIntersectionObserver() {
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { rootMargin: '0px 0px -60px 0px', threshold: 0.05 });
  document.querySelectorAll('.masonry-item').forEach((item, i) => {
    item.style.transitionDelay = (i % 12) * 40 + 'ms';
    obs.observe(item);
  });
}

// ---- HELPERS ----
function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
function scrollTo(id)   { document.getElementById(id).scrollIntoView({ behavior: 'smooth' }); }
</script>
